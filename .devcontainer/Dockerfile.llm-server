FROM python:3.12-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends build-essential cmake \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Build from source so libllama is always present in the final wheel.
ENV FORCE_CMAKE=1 \
    CMAKE_ARGS="-DGGML_NATIVE=OFF"

RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir --no-binary=llama-cpp-python "llama-cpp-python[server]==0.3.16"
